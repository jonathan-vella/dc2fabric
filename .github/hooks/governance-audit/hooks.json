{
  "hooks": {
    "SessionStart": [
      {
        "type": "command",
        "command": "bash .github/hooks/governance-audit/audit-session-start.sh",
        "timeout": 5
      }
    ],
    "Stop": [
      {
        "type": "command",
        "command": "bash .github/hooks/governance-audit/audit-session-end.sh",
        "timeout": 5
      }
    ],
    "UserPromptSubmit": [
      {
        "type": "command",
        "command": "bash .github/hooks/governance-audit/audit-prompt.sh",
        "timeout": 10
      }
    ]
  }
}
