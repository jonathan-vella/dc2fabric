      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "text": "As-Built reads prior artifacts and deployed resource state.\nIt produces the 07-*.md documentation suite for workload handoff.\nThe workflow closes with human-governed documentation delivery.",
      "fontSize": 17,
