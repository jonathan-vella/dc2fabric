{
  "name": "azure-agentic-infraops",
  "version": "0.10.0",
  "description": "APEX - Agentic Platform Engineering eXperience for Azure. Verified. Well-Architected. Deployable.",
  "private": true,
  "scripts": {
    "prepare": "lefthook install",
    "lint:md": "markdownlint-cli2",
    "lint:md:fix": "markdownlint-cli2 --fix",
    "lint:links": "find . -name '*.md' ! -path './node_modules/*' ! -path './infra/*' ! -path './site/node_modules/*' ! -path './site/dist/*' | xargs -I {} markdown-link-check {} --config .markdown-link-check.json",
    "lint:links:docs": "find site/src/content/docs \\( -name '*.md' -o -name '*.mdx' \\) ! -path '*/demo/*' | xargs -I {} markdown-link-check {} --config .markdown-link-check-site.json",
    "docs:dev": "cd site && npm run dev",
    "docs:build": "cd site && npm run build",
    "docs:preview": "cd site && npm run preview",
    "validate:artifacts": "node scripts/validate-artifacts.mjs",
    "fix:artifacts": "node scripts/validate-artifacts.mjs --fix",
    "lint:artifact-templates": "node scripts/validate-artifacts.mjs",
    "lint:h2-sync": "node scripts/validate-artifacts.mjs",
    "fix:artifact-h2": "node scripts/validate-artifacts.mjs --fix",
    "lint:version-sync": "node scripts/validate-version-sync.mjs",
    "lint:deprecated-refs": "node scripts/validate-no-deprecated-refs.mjs",
    "lint:mcp-config": "node scripts/validate-mcp-config.mjs",
    "lint:docs-freshness": "node scripts/check-docs-freshness.mjs",
    "validate:agents": "node scripts/validate-agents.mjs",
    "lint:agent-frontmatter": "node scripts/validate-agents.mjs",
    "lint:skills-format": "node scripts/validate-skills.mjs",
    "lint:governance-refs": "node scripts/validate-governance-refs.mjs",
    "validate:instruction-checks": "node scripts/validate-instruction-checks.mjs",
    "validate:session-state": "node scripts/validate-session-state.mjs",
    "lint:prose": "vale --config .vale.ini site/src/content/docs/ .github/ README.md || echo 'Vale not installed - run: brew install vale'",
    "lint:json": "node scripts/lint-json.mjs",
    "lint:yaml": "find . \\( -name '*.yml' -o -name '*.yaml' \\) ! -path './node_modules/*' ! -path './infra/*' -exec yamllint -c .yamllint.yml {} \\; 2>/dev/null || echo 'yamllint not installed - run: pip install yamllint'",
    "lint:python": "cd mcp/azure-pricing-mcp && python -m ruff check src/ tests/",
    "lint:python:fix": "cd mcp/azure-pricing-mcp && python -m ruff check --fix src/ tests/",
    "lint:drawio": "node scripts/validate-drawio-files.mjs",
    "lint:terraform-fmt": "terraform fmt -check -recursive infra/terraform/",
    "validate:terraform": "for dir in infra/terraform/*/; do [ -f \"$dir/main.tf\" ] && (cd \"$dir\" && terraform init -backend=false -input=false > /dev/null 2>&1 && terraform validate) || true; done",
    "validate:vscode": "node scripts/validate-vscode-config.mjs",
    "fetch:deprecations": "node scripts/fetch-azure-deprecations.mjs",
    "snapshot:baseline": "bash scripts/snapshot-agent-context.sh",
    "diff:baseline": "bash scripts/diff-context-baseline.sh",
    "lint:agent-checks": "node scripts/validate-agents.mjs",
    "lint:glob-audit": "node scripts/validate-glob-audit.mjs",
    "validate:skills": "node scripts/validate-skills.mjs",
    "lint:skill-references": "node scripts/validate-skills.mjs",
    "lint:orphaned-content": "node scripts/validate-orphaned-content.mjs",
    "validate:session-lock": "node scripts/validate-session-lock.mjs",
    "validate:workflow-graph": "node scripts/validate-workflow-graph.mjs",
    "validate:agent-registry": "node scripts/validate-agent-registry.mjs",
    "validate:skill-affinity": "node scripts/validate-skills.mjs",
    "validate:skill-checks": "node scripts/validate-skill-checks.mjs",
    "validate:stale-refs": "node scripts/validate-skills.mjs",
    "lint:model-alignment": "node scripts/validate-agents.mjs",
    "generate:digests": "node scripts/generate-skill-digests.mjs",
    "e2e:validate": "node scripts/validate-e2e-step.mjs all",
    "e2e:benchmark": "node scripts/benchmark-e2e.mjs",
    "e2e:combine": "node scripts/combine-e2e-runs.mjs",
    "export:agent-output-html": "python3 scripts/export-agent-output-html.py",
    "init": "node scripts/init-from-template.mjs",
    "sync:workflows": "node scripts/sync-workflows.mjs",
    "validate:no-hardcoded-counts": "node scripts/validate-no-hardcoded-counts.mjs",
    "validate:hooks": "node scripts/validate-hooks.mjs",
    "validate:iac-security-baseline": "node scripts/validate-iac-security-baseline.mjs",
    "validate:terminology": "node scripts/validate-terminology.mjs",
    "build:drawio-icons": "python scripts/convert-azure-icons-to-drawio.py",
    "test:hooks": "bash tests/test-hooks.sh",
    "validate:_node": "run-p validate:artifacts validate:agents validate:skills lint:version-sync lint:deprecated-refs lint:mcp-config validate:instruction-checks lint:governance-refs validate:session-state validate:session-lock validate:workflow-graph validate:agent-registry validate:skill-checks lint:json lint:glob-audit lint:orphaned-content lint:docs-freshness validate:no-hardcoded-counts validate:hooks validate:iac-security-baseline validate:vscode lint:drawio validate:terminology",
    "validate:_node-ci": "run-p validate:artifacts validate:agents validate:skills lint:version-sync lint:deprecated-refs lint:mcp-config lint:governance-refs validate:instruction-checks validate:session-state validate:session-lock validate:workflow-graph validate:agent-registry validate:skill-checks lint:json lint:glob-audit lint:orphaned-content validate:vscode lint:drawio",
    "validate:_external": "run-p lint:md lint:python lint:terraform-fmt validate:terraform",
    "validate:all": "run-p --continue-on-error validate:_node validate:_external && echo '✅ All validations passed'",
    "audit:quarterly": "run-p lint:glob-audit lint:orphaned-content lint:docs-freshness"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "fast-xml-parser": "^5.5.10",
    "jsdom": "^29.0.1",
    "lefthook": "^2.1.4",
    "markdown-link-check": "^3.14.2",
    "markdownlint-cli2": "^0.21.0",
    "npm-run-all2": "^8.0.4"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/jonathan-vella/azure-agentic-infraops.git"
  },
  "keywords": [
    "azure",
    "bicep",
    "github-copilot",
    "infrastructure-as-code",
    "agents",
    "agentic",
    "well-architected",
    "azure-verified-modules"
  ],
  "author": "Jonathan Vella",
  "license": "MIT",
  "overrides": {
    "undici": ">=7.24.0",
    "dompurify": ">=3.3.2",
    "nanoid": ">=3.3.8",
    "mermaid": ">=11.4.1"
  }
}
